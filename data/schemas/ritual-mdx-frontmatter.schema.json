{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quietash.local/schemas/ritual-mdx-frontmatter.schema.json",
  "title": "Ritual article (MDX frontmatter)",
  "description": "Editorial ritual detail page — THE RITUAL grid + objects strip are data-driven for new posts under content/rituals/*.mdx.",
  "type": "object",
  "required": [
    "title",
    "excerpt",
    "mood",
    "relatedProducts",
    "ritual_section",
    "objects_section"
  ],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "excerpt": { "type": "string", "minLength": 1 },
    "mood": { "type": "string", "minLength": 1 },
    "relatedProducts": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "coverImage": { "type": "string" },
    "intro_aside_image": { "type": "string" },
    "reading_time": { "type": "integer", "minimum": 1 },
    "next_ritual": { "type": "string", "minLength": 1 },
    "related_essay": { "type": "string", "minLength": 1 },
    "closing_quote": { "type": "string" },
    "ritual_section": {
      "type": "object",
      "required": ["label", "steps"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["title", "body", "image"],
            "properties": {
              "title": { "type": "string" },
              "body": { "type": "string" },
              "image": { "type": "string", "pattern": "^/" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "objects_section": {
      "type": "object",
      "required": ["label", "subtext", "cta_label", "cta_href"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "subtext": { "type": "string", "minLength": 1 },
        "cta_label": { "type": "string", "minLength": 1 },
        "cta_href": { "type": "string", "pattern": "^/" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}

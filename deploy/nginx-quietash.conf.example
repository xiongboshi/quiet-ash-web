# Example nginx in front of `next start` (port 3000).
# Run `npm run build && npm run gzip:static` so `.gz` siblings exist for gzip_static.

upstream quietash_next {
  server 127.0.0.1:3000;
  keepalive 64;
}

server {
  listen 80;
  server_name www.quietash.life quietash.life;

  gzip on;
  gzip_vary on;
  gzip_proxied any;
  gzip_comp_level 6;
  gzip_min_length 256;
  gzip_types
    text/css
    text/javascript
    application/javascript
    application/json
    application/xml
    image/svg+xml
    font/woff2;

  # Serve pre-built .gz for /_next/static when present (see npm run gzip:static)
  gzip_static on;

  location /_next/static/ {
    alias /var/www/quietash/.next/static/;
    expires 1y;
    add_header Cache-Control "public, max-age=31536000, immutable";
    access_log off;
  }

  location / {
    proxy_pass http://quietash_next;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Connection "";
  }
}
